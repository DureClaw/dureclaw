{
  "$schema": "https://opencode.ai/config.schema.json",
  "plugins": [".opencode/plugin/harness.ts"],
  "agents": {
    "orchestrator": {
      "path": ".opencode/agents/orchestrator.md",
      "mode": "primary",
      "permissions": {
        "read": ["**/*"],
        "write": [".opencode/state/**", ".opencode/reports/**"],
        "bash": ["ls", "cat", "find", "grep", "echo", "date", "wc"],
        "task": true
      }
    },
    "planner": {
      "path": ".opencode/agents/planner.md",
      "mode": "subagent",
      "permissions": {
        "read": ["**/*"],
        "write": ["*.md", "docs/**", ".opencode/state/**"],
        "bash": false,
        "task": false
      }
    },
    "builder": {
      "path": ".opencode/agents/builder.md",
      "mode": "subagent",
      "permissions": {
        "read": ["**/*"],
        "write": ["**/*"],
        "bash": true,
        "task": false
      }
    },
    "verifier": {
      "path": ".opencode/agents/verifier.md",
      "mode": "subagent",
      "permissions": {
        "read": ["**/*"],
        "write": [".opencode/reports/**"],
        "bash": [
          "bun test", "npm test", "yarn test",
          "bun run lint", "bun run typecheck",
          "bash .opencode/hooks/*.sh",
          "cat .opencode/reports/*"
        ],
        "task": false
      }
    },
    "reviewer": {
      "path": ".opencode/agents/reviewer.md",
      "mode": "subagent",
      "permissions": {
        "read": ["**/*"],
        "write": [".opencode/state/mailbox/**"],
        "bash": false,
        "task": false
      }
    }
  },
  "hooks": {
    "tool.execute.before": ".opencode/plugin/harness.ts#onToolBefore",
    "tool.execute.after": ".opencode/plugin/harness.ts#onToolAfter",
    "session.idle": ".opencode/plugin/harness.ts#onSessionIdle",
    "experimental.session.stop": ".opencode/plugin/harness.ts#onSessionStop"
  },
  "customTools": {
    "run_hook": ".opencode/plugin/harness.ts#toolRunHook",
    "read_state": ".opencode/plugin/harness.ts#toolReadState",
    "write_state": ".opencode/plugin/harness.ts#toolWriteState",
    "post_message": ".opencode/plugin/harness.ts#toolPostMessage",
    "read_mailbox": ".opencode/plugin/harness.ts#toolReadMailbox"
  }
}
