{
  "name": "open-agent-harness",
  "version": "0.1.0",
  "description": "5-agent AI development workflow harness for OpenCode",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "init": "bash scripts/init.sh",
    "agent": "bun run packages/agent-daemon/src/index.ts",
    "mcp": "bun run packages/oah-mcp/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
