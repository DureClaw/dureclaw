#!/usr/bin/env bash
# oah — Open Agent Harness CLI
#
# 설치: setup-agent.sh 실행 시 자동으로 ~/.local/bin/oah 에 설치됨
#
# 사용법:
#   oah                    # 포그라운드 실행 (기본)
#   oah start              # 백그라운드 실행
#   oah stop               # 중지
#   oah restart            # 재시작
#   oah status             # 상태 확인
#   oah logs               # 로그 보기
#   oah update             # 에이전트 최신 버전으로 업데이트
#   oah config             # 현재 설정 출력
#   oah service install    # systemd/launchd 서비스 등록
#   oah service remove     # 서비스 해제
#   oah service start      # 서비스 시작
#   oah service stop       # 서비스 중지
#   oah service restart    # 서비스 재시작
#   oah service status     # 서비스 상태
#   oah service logs       # 서비스 로그

set -euo pipefail

# ─── 경로 ─────────────────────────────────────────────────────────────────────

OAH_DIR="$HOME/.oah"
OAH_CONFIG="$OAH_DIR/config"
OAH_PID="$OAH_DIR/oah.pid"
OAH_LOG="$OAH_DIR/oah.log"
OAH_SOUL="$OAH_DIR/soul.md"
OAH_BASE="https://open-agent-harness.baryon.ai"

mkdir -p "$OAH_DIR"

# ─── 설정 로드 ────────────────────────────────────────────────────────────────

# defaults
PHOENIX=""
ROLE="builder"
WK=""
DIR="$HOME"
NAME=""
BACKEND="auto"

[[ -f "$OAH_CONFIG" ]] && source "$OAH_CONFIG"

NAME="${NAME:-${ROLE}@$(hostname -s 2>/dev/null || hostname)}"

# ─── 헬퍼 ─────────────────────────────────────────────────────────────────────

_arch() { uname -m; }

_is_arm32() {
  local a; a=$(_arch)
  [[ "$a" == armv7l || "$a" == armv6l ]]
}

_exe_cmd() {
  if _is_arm32; then
    echo "node $HOME/.oah-agent.js"
  else
    echo "$HOME/.oah-agent"
  fi
}

_is_running() {
  [[ -f "$OAH_PID" ]] && kill -0 "$(cat "$OAH_PID")" 2>/dev/null
}

_require_config() {
  if [[ -z "$PHOENIX" ]]; then
    _first_run_wizard
  fi
}

# ─── First-run 설정 마법사 ────────────────────────────────────────────────────

_ts_online_peers_oah() {
  local ts
  ts=$(command -v tailscale 2>/dev/null) || return 1
  "$ts" status --json 2>/dev/null \
    | python3 -c "
import sys, json
data = json.load(sys.stdin)
for v in (data.get('Peer') or {}).values():
    if v.get('Online'):
        ips = v.get('TailscaleIPs', [])
        ip = ips[0] if ips else ''
        print(v.get('HostName','?') + '  [' + ip + ']|ws://' + ip + ':4000')
" 2>/dev/null
}

_ts_tui_oah() {
  local IFS=$'\n'
  local lines=()
  while read -r line; do lines+=("$line"); done < <(_ts_online_peers_oah)
  [[ ${#lines[@]} -eq 0 ]] && return 1

  local idx=0
  tput civis 2>/dev/null
  trap 'tput cnorm 2>/dev/null' EXIT INT

  while true; do
    tput clear 2>/dev/null || clear
    echo ""
    echo "  OAH  서버 선택"
    echo "  ──────────────────────────────────────"
    echo ""
    for i in "${!lines[@]}"; do
      local label="${lines[$i]%%|*}"
      if [[ $i -eq $idx ]]; then
        printf "  \033[1;32m> %s\033[0m\n" "$label"
      else
        printf "    %s\n" "$label"
      fi
    done
    echo ""
    echo "  [↑/↓] 선택   [Enter] 연결   [q] 직접입력"

    local key
    IFS= read -rsn1 key
    case "$key" in
      $'\x1b')
        IFS= read -rsn2 -t 0.1 key
        case "$key" in
          '[A') [[ $idx -gt 0 ]] && ((idx--)) ;;
          '[B') [[ $idx -lt $((${#lines[@]}-1)) ]] && ((idx++)) ;;
        esac ;;
      '') # Enter
        tput cnorm 2>/dev/null
        PHOENIX="${lines[$idx]#*|}"
        return 0 ;;
      q|Q)
        tput cnorm 2>/dev/null
        return 2 ;;
    esac
  done
}

_first_run_wizard() {
  echo ""
  echo "  ╔══════════════════════════════════════╗"
  echo "  ║   OAH — 첫 번째 실행 설정           ║"
  echo "  ╚══════════════════════════════════════╝"
  echo ""

  # 서버 자동 탐색
  if curl -sf --max-time 3 "http://oah.local:4000/api/health" > /dev/null 2>&1; then
    PHOENIX="ws://oah.local:4000"
    echo "  ✅ oah.local 서버 발견: $PHOENIX"
  elif command -v tailscale &>/dev/null; then
    echo "  Tailscale 피어에서 OAH 서버 탐색 중..."
    if _ts_tui_oah; then
      echo "  ✅ 선택: $PHOENIX"
    else
      echo ""
      printf "  서버 WebSocket 주소 입력 (예: ws://192.168.1.10:4000): "
      read -r PHOENIX
    fi
  else
    echo ""
    printf "  서버 WebSocket 주소 입력 (예: ws://192.168.1.10:4000): "
    read -r PHOENIX
  fi

  if [[ -z "$PHOENIX" ]]; then
    echo "  오류: 서버 주소가 필요합니다."
    exit 1
  fi

  # ROLE 선택
  echo ""
  echo "  역할 선택:"
  echo "    1) builder      (기본 — 코드 작성/실행)"
  echo "    2) orchestrator (태스크 분배)"
  echo "    3) executor     (명령어 실행 전용)"
  echo "    4) analyzer     (코드 분석 전용)"
  printf "  역할 [1]: "
  read -r role_input
  case "${role_input:-1}" in
    2|orchestrator) ROLE="orchestrator" ;;
    3|executor)     ROLE="executor" ;;
    4|analyzer)     ROLE="analyzer" ;;
    *)              ROLE="builder" ;;
  esac

  # DIR
  printf "  프로젝트 디렉토리 [%s]: " "$(pwd)"
  read -r dir_input
  DIR="${dir_input:-$(pwd)}"

  NAME="${ROLE}@$(hostname -s 2>/dev/null || hostname)"

  # 저장
  mkdir -p "$OAH_DIR"
  cat > "$OAH_CONFIG" <<CFG
PHOENIX=$PHOENIX
ROLE=$ROLE
BACKEND=auto
DIR=$DIR
WK=
NAME=$NAME
CFG

  echo ""
  echo "  ✅ 설정 저장됨: $OAH_CONFIG"
  echo ""
}

_server_status() {
  local http="${PHOENIX/ws:/http:}"
  http="${http/wss:/https:}"
  if curl -sf --max-time 3 "$http/api/health" 2>/dev/null; then
    return 0
  fi
  return 1
}

_print_banner() {
  local node_label=""
  _is_arm32 && node_label="  [Node.js/32-bit]" || node_label=""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo " oah-agent  $NAME$node_label"
  echo " server  →  $PHOENIX"
  echo " backend →  $BACKEND"
  echo " dir     →  $DIR"
  [[ -n "$WK" ]] && echo " work-key→  $WK"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

_run_env() {
  env \
    STATE_SERVER="$PHOENIX" \
    AGENT_NAME="$NAME" \
    AGENT_ROLE="$ROLE" \
    AGENT_BACKEND="$BACKEND" \
    WORK_KEY="${WK:-}" \
    PROJECT_DIR="$DIR" \
    "$@"
}

# ─── 명령어 ───────────────────────────────────────────────────────────────────

cmd_status() {
  echo ""
  echo "  oah-agent 상태"
  echo "  ──────────────────────────────────────"

  # 프로세스 상태
  if _is_running; then
    local pid; pid=$(cat "$OAH_PID")
    echo "  프로세스  ✅ 실행 중  (PID $pid)"
  else
    echo "  프로세스  ○ 중지됨"
  fi

  # 설정
  echo "  서버      ${PHOENIX:-"(미설정)"}"
  echo "  역할      $ROLE"
  echo "  백엔드    $BACKEND"
  echo "  디렉토리  $DIR"
  [[ -n "$WK" ]] && echo "  Work Key  $WK"

  # 서버 연결
  echo ""
  if [[ -n "$PHOENIX" ]]; then
    if _server_status > /dev/null 2>&1; then
      local health; health=$(_server_status 2>/dev/null)
      local ver; ver=$(echo "$health" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('version','?'))" 2>/dev/null || echo "?")
      local wks; wks=$(echo "$health" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('work_keys',0))" 2>/dev/null || echo "?")
      echo "  서버 연결 ✅ 온라인  (v$ver, WK=${wks}개)"
    else
      echo "  서버 연결 ✗ 오프라인"
    fi
  else
    echo "  서버 연결 — (서버 미설정)"
  fi

  # 서비스 상태
  echo ""
  local svc_status="없음"
  if [[ "$(uname)" == "Darwin" ]]; then
    local plist="$HOME/Library/LaunchAgents/ai.baryon.oah-agent.plist"
    [[ -f "$plist" ]] && svc_status="launchd 등록됨"
  else
    local unit="$HOME/.config/systemd/user/oah-agent.service"
    if [[ -f "$unit" ]]; then
      if systemctl --user is-active oah-agent &>/dev/null; then
        svc_status="systemd ✅ active"
      else
        svc_status="systemd ○ inactive"
      fi
    fi
  fi
  echo "  서비스    $svc_status"
  echo ""
}

cmd_start() {
  _require_config
  if _is_running; then
    local pid; pid=$(cat "$OAH_PID")
    echo "이미 실행 중입니다. (PID $pid)"
    return
  fi

  _print_banner
  local exe_cmd; exe_cmd=$(_exe_cmd)

  # shellcheck disable=SC2086
  _run_env nohup $exe_cmd >> "$OAH_LOG" 2>&1 &
  echo $! > "$OAH_PID"
  sleep 1

  if _is_running; then
    echo "✅ 시작됨  (PID $(cat "$OAH_PID"))"
    echo "   로그: oah logs"
  else
    echo "✗ 시작 실패. 로그 확인:"
    tail -20 "$OAH_LOG"
    exit 1
  fi
}

cmd_stop() {
  if ! _is_running; then
    echo "실행 중이지 않습니다."
    rm -f "$OAH_PID"
    return
  fi
  local pid; pid=$(cat "$OAH_PID")
  kill "$pid" 2>/dev/null && rm -f "$OAH_PID"
  echo "✅ 중지됨  (PID $pid)"
}

cmd_restart() {
  cmd_stop || true
  sleep 1
  cmd_start
}

cmd_logs() {
  local n="${2:-50}"
  if [[ ! -f "$OAH_LOG" ]]; then
    echo "로그 파일 없음: $OAH_LOG"
    return
  fi
  tail -f -n "$n" "$OAH_LOG"
}

cmd_config() {
  local sub="${1:-}"
  if [[ "$sub" == "set" ]]; then
    cmd_config_set "${2:-}"
    return
  fi
  echo ""
  echo "  설정 파일: $OAH_CONFIG"
  echo "  ──────────────────────────────────────"
  if [[ -f "$OAH_CONFIG" ]]; then
    while IFS= read -r line; do
      echo "  $line"
    done < "$OAH_CONFIG"
  else
    echo "  (없음 — oah init 을 실행하세요)"
  fi
  echo ""
  echo "  변경: oah config set PHOENIX=ws://... | oah config set ROLE=builder"
  echo ""
}

cmd_init() {
  echo ""
  echo "  기존 설정을 초기화하고 재설정합니다."
  if [[ -f "$OAH_CONFIG" ]]; then
    echo "  현재 설정:"
    while IFS= read -r line; do
      [[ "$line" =~ ^[A-Z] ]] && echo "    $line"
    done < "$OAH_CONFIG"
    echo ""
    printf "  계속하시겠습니까? [y/N]: "
    read -r confirm
    [[ ! "${confirm,,}" =~ ^y ]] && echo "  취소됨." && return
    rm -f "$OAH_CONFIG"
  fi
  # 설정을 초기화 후 first-run 마법사 재실행
  PHOENIX=""
  _first_run_wizard
  echo "  oah 를 실행하려면: oah start"
}

cmd_doctor() {
  local ok=true
  echo ""
  echo "  oah doctor — 시스템 진단"
  echo "  ──────────────────────────────────────"

  # 1. 설정 파일
  if [[ -f "$OAH_CONFIG" ]]; then
    echo "  [✅] 설정 파일   $OAH_CONFIG"
  else
    echo "  [✗ ] 설정 파일   없음 — oah init 실행 필요"
    ok=false
  fi

  # 2. 서버 연결
  if [[ -z "$PHOENIX" ]]; then
    echo "  [✗ ] 서버        PHOENIX 미설정"
    ok=false
  else
    local http="${PHOENIX/ws:/http:}"; http="${http/wss:/https:}"
    if curl -sf --max-time 5 "$http/api/health" > /dev/null 2>&1; then
      local ver
      ver=$(curl -sf --max-time 5 "$http/api/health" | python3 -c "import sys,json; print(json.load(sys.stdin).get('version','?'))" 2>/dev/null || echo "?")
      echo "  [✅] 서버 연결   $PHOENIX  (v$ver)"
    else
      echo "  [✗ ] 서버 연결   $PHOENIX — 응답 없음"
      ok=false
    fi
  fi

  # 3. 에이전트 바이너리
  if _is_arm32; then
    if [[ -f "$HOME/.oah-agent.js" ]]; then
      local sz; sz=$(du -sh "$HOME/.oah-agent.js" | cut -f1)
      echo "  [✅] 바이너리    ~/.oah-agent.js  ($sz)"
    else
      echo "  [✗ ] 바이너리    ~/.oah-agent.js 없음"
      ok=false
    fi
  else
    if [[ -f "$HOME/.oah-agent" ]]; then
      local sz; sz=$(du -sh "$HOME/.oah-agent" | cut -f1)
      echo "  [✅] 바이너리    ~/.oah-agent  ($sz)"
    else
      echo "  [✗ ] 바이너리    ~/.oah-agent 없음"
      ok=false
    fi
  fi

  # 4. AI 백엔드
  echo ""
  echo "  AI 백엔드 탐지:"
  local found_any=false
  for backend in claude opencode gemini codex aider zeroclaw; do
    local bin_name="$backend"
    [[ "$backend" == "claude" ]] && bin_name="claude"
    if command -v "$bin_name" &>/dev/null; then
      local ver_out
      ver_out=$("$bin_name" --version 2>/dev/null | head -1 || echo "")
      echo "  [✅] $backend   $(command -v "$bin_name")  $ver_out"
      found_any=true
    else
      echo "  [ ] $backend   (없음)"
    fi
  done
  if ! $found_any; then
    echo "  ⚠  AI 백엔드를 찾지 못했습니다. [SHELL] 태스크만 실행 가능."
  fi

  # 5. Node.js (armhf)
  if _is_arm32; then
    echo ""
    if command -v node &>/dev/null; then
      local nv; nv=$(node --version 2>/dev/null || echo "?")
      echo "  [✅] Node.js     $nv"
    else
      echo "  [✗ ] Node.js     미설치 — sudo apt install nodejs"
      ok=false
    fi
  fi

  # 6. oah CLI PATH
  echo ""
  if command -v oah &>/dev/null; then
    echo "  [✅] oah PATH    $(command -v oah)"
  else
    echo "  [✗ ] oah PATH    ~/.local/bin 이 PATH에 없음"
    echo "         → export PATH=\"\$HOME/.local/bin:\$PATH\""
    ok=false
  fi

  # 7. 프로세스 상태
  echo ""
  if _is_running; then
    echo "  [✅] 프로세스    실행 중  (PID $(cat "$OAH_PID"))"
  else
    echo "  [ ] 프로세스    중지됨"
  fi

  echo ""
  echo "  ──────────────────────────────────────"
  if $ok; then
    echo "  ✅ 모든 항목 정상"
  else
    echo "  ⚠  일부 항목 수정 필요 (위 [✗] 항목 확인)"
  fi
  echo ""
}

cmd_kill() {
  echo ""
  local stopped=false

  # 백그라운드 프로세스 종료
  if _is_running; then
    local pid; pid=$(cat "$OAH_PID")
    kill -9 "$pid" 2>/dev/null && rm -f "$OAH_PID"
    echo "  ✅ 에이전트 강제 종료  (PID $pid)"
    stopped=true
  fi

  # systemd 서비스 강제 종료
  if command -v systemctl &>/dev/null && systemctl --user is-active oah-agent &>/dev/null; then
    systemctl --user kill -s SIGKILL oah-agent 2>/dev/null || true
    echo "  ✅ systemd 서비스 강제 종료"
    stopped=true
  fi

  # 잔여 프로세스 탐색
  local stale_pids
  stale_pids=$(pgrep -f "oah-agent\|node.*oah-agent.js" 2>/dev/null || true)
  if [[ -n "$stale_pids" ]]; then
    echo "$stale_pids" | xargs kill -9 2>/dev/null || true
    echo "  ✅ 잔여 프로세스 종료: $stale_pids"
    stopped=true
  fi

  $stopped || echo "  실행 중인 oah-agent 없음"
  echo ""
}

cmd_completions() {
  local shell="${1:-bash}"
  case "$shell" in
    bash)
      cat <<'BASH'
# oah bash completion
# 사용: source <(oah completions bash)
#   또는: oah completions bash >> ~/.bashrc

_oah_completions() {
  local cur prev words
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  local commands="status start stop restart logs config update init doctor kill service completions help"
  local service_cmds="install remove start stop restart status logs"

  case "$prev" in
    oah)
      COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
      ;;
    service)
      COMPREPLY=( $(compgen -W "$service_cmds" -- "$cur") )
      ;;
    completions)
      COMPREPLY=( $(compgen -W "bash zsh" -- "$cur") )
      ;;
    config)
      COMPREPLY=( $(compgen -W "set" -- "$cur") )
      ;;
    logs)
      COMPREPLY=( $(compgen -W "10 50 100 200" -- "$cur") )
      ;;
  esac
}
complete -F _oah_completions oah
BASH
      ;;
    zsh)
      cat <<'ZSH'
# oah zsh completion
# 사용: source <(oah completions zsh)
#   또는: oah completions zsh >> ~/.zshrc

_oah() {
  local -a commands
  commands=(
    'status:상태 확인 (프로세스, 서버, 서비스)'
    'start:백그라운드 실행'
    'stop:중지'
    'restart:재시작'
    'logs:로그 보기'
    'config:설정 출력/변경'
    'update:최신 버전 업데이트'
    'init:설정 재마법사'
    'doctor:시스템 진단'
    'kill:강제 종료'
    'service:OS 서비스 관리'
    'completions:셸 자동완성 스크립트'
    'help:도움말'
  )

  local -a service_cmds
  service_cmds=(
    'install:서비스 등록' 'remove:서비스 제거'
    'start:서비스 시작' 'stop:서비스 중지'
    'restart:서비스 재시작' 'status:서비스 상태'
    'logs:서비스 로그'
  )

  _arguments \
    '1: :->command' \
    '*: :->args'

  case $state in
    command) _describe 'oah commands' commands ;;
    args)
      case $words[2] in
        service)   _describe 'service subcommands' service_cmds ;;
        completions) _values 'shell' bash zsh ;;
      esac
      ;;
  esac
}
compdef _oah oah
ZSH
      ;;
    *)
      echo "지원하는 셸: bash, zsh"
      echo "사용: oah completions bash | oah completions zsh"
      ;;
  esac
}

cmd_config_set() {
  local kv="${1:-}"
  if [[ -z "$kv" || ! "$kv" =~ ^[A-Z_]+=.* ]]; then
    echo "사용: oah config set KEY=VALUE"
    echo "키:   PHOENIX  ROLE  BACKEND  DIR  WK  NAME"
    echo "예:   oah config set PHOENIX=ws://192.168.1.10:4000"
    return 1
  fi
  local key="${kv%%=*}"
  local val="${kv#*=}"
  mkdir -p "$OAH_DIR"
  if [[ -f "$OAH_CONFIG" ]]; then
    # 기존 키 교체 또는 추가
    local tmpfile; tmpfile=$(mktemp)
    local found=false
    while IFS= read -r line; do
      if [[ "$line" =~ ^${key}= ]]; then
        echo "${key}=${val}" >> "$tmpfile"
        found=true
      else
        echo "$line" >> "$tmpfile"
      fi
    done < "$OAH_CONFIG"
    $found || echo "${key}=${val}" >> "$tmpfile"
    mv "$tmpfile" "$OAH_CONFIG"
  else
    echo "${key}=${val}" > "$OAH_CONFIG"
  fi
  echo "✅ $key = $val"
  # 현재 세션에도 반영
  export "$key"="$val"
}

cmd_soul() {
  local sub="${1:-show}"
  case "$sub" in
    show|cat)
      echo ""
      if [[ -f "$OAH_SOUL" ]]; then
        cat "$OAH_SOUL"
      else
        echo "  soul 파일 없음. 생성: oah soul init"
      fi
      echo ""
      ;;

    edit)
      ${EDITOR:-vi} "$OAH_SOUL"
      ;;

    path)
      echo "$OAH_SOUL"
      ;;

    init|generate)
      echo ""
      echo "  Agent Soul 생성 중..."
      echo ""

      # ── 하드웨어 정보 수집 ──
      local hostname; hostname=$(hostname -s 2>/dev/null || hostname)
      local os_name os_ver cpu ram gpu disk
      os_name=$(uname -s)
      if [[ "$os_name" == "Darwin" ]]; then
        os_ver=$(sw_vers -productVersion 2>/dev/null || echo "macOS")
        cpu=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "unknown")
        ram_bytes=$(sysctl -n hw.memsize 2>/dev/null || echo "0")
        ram="$((ram_bytes / 1073741824)) GB"
        # Apple GPU 감지
        if [[ "$cpu" == *"Apple"* ]]; then
          gpu="$cpu GPU (Metal)"
        else
          gpu=$(system_profiler SPDisplaysDataType 2>/dev/null | grep "Chipset" | head -1 | awk -F: '{print $2}' | xargs)
        fi
      elif [[ "$os_name" == "Linux" ]]; then
        os_ver=$(. /etc/os-release 2>/dev/null && echo "$PRETTY_NAME" || uname -r)
        cpu=$(grep -m1 "model name" /proc/cpuinfo 2>/dev/null | awk -F: '{print $2}' | xargs || echo "unknown")
        ram_kb=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}' || echo "0")
        ram="$((ram_kb / 1048576)) GB"
        gpu=""
        # NVIDIA
        command -v nvidia-smi &>/dev/null && gpu=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1) || true
        # Raspberry Pi
        [[ -f /proc/device-tree/model ]] && cpu="$(cat /proc/device-tree/model 2>/dev/null | tr -d '\0')" || true
      fi
      disk=$(df -h / 2>/dev/null | tail -1 | awk '{print $2 " total, " $4 " free"}')
      local arch; arch=$(uname -m)

      # ── AI 백엔드 ──
      local backends=()
      for b in claude opencode gemini codex aider zeroclaw; do
        command -v "$b" &>/dev/null && backends+=("$b")
      done
      local backends_str; backends_str=$(IFS=", "; echo "${backends[*]:-없음}")

      # ── 개발 도구 ──
      local tools=()
      for t in git gh node bun python3 docker make cargo go; do
        command -v "$t" &>/dev/null && tools+=("$t")
      done
      local tools_str; tools_str=$(IFS=", "; echo "${tools[*]:-없음}")

      # ── ROLE / WK ──
      [[ -f "$OAH_CONFIG" ]] && source "$OAH_CONFIG" 2>/dev/null || true
      local role_val="${ROLE:-builder}"
      local phoenix_val="${PHOENIX:-}"

      # ── soul.md 작성 ──
      mkdir -p "$OAH_DIR"
      cat > "$OAH_SOUL" <<SOUL
---
agent: ${role_val}@${hostname}
machine: ${hostname}
role: ${role_val}
updated: $(date -u +%Y-%m-%dT%H:%M:%SZ)
---

# Agent Soul — ${hostname}

## Identity
- **Name**: ${role_val}@${hostname}
- **Hostname**: ${hostname}
- **OS**: ${os_name} ${os_ver}
- **Arch**: ${arch}
- **CPU**: ${cpu}
- **RAM**: ${ram}
- **GPU**: ${gpu:-없음}
- **Disk**: ${disk}

## Role & Specialization
- **Role**: ${role_val}
- **Server**: ${phoenix_val:-미설정}

이 머신의 전문 분야와 특기를 여기에 기술하세요.
예: "Apple M4 기반 macOS 빌드 전문, Docker 이미지 빌드 및 배포 담당"

## AI Backends
${backends_str}

## Available Tools
${tools_str}

## Working Style
이 에이전트가 태스크를 처리하는 방식을 기술하세요.
예: "코드 품질을 최우선으로 하며, 테스트 작성 후 구현하는 TDD 방식을 선호합니다."

## Constraints & Notes
- 특별한 제약이나 주의사항을 여기에 기술하세요.

## Context
현재 담당하고 있는 프로젝트나 작업 컨텍스트를 기술하세요.
SOUL

      echo "  ✅ 생성됨: $OAH_SOUL"
      echo ""
      echo "  내용 확인:  oah soul show"
      echo "  편집:       oah soul edit"
      echo ""
      ;;

    *)
      echo "사용: oah soul [show|init|edit|path]"
      ;;
  esac
}

cmd_update() {
  echo "→ 최신 에이전트 다운로드 중..."
  local nc; nc=$(date +%Y%m%d%H%M)
  if _is_arm32; then
    curl -fsSL "$OAH_BASE/oah-agent.js?nc=$nc" -o "$HOME/.oah-agent.js"
    echo "✅ ~/.oah-agent.js 업데이트 완료"
  else
    local os arch binary_name
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    arch=$(uname -m)
    [[ "$arch" == "x86_64" ]] && arch="x64"
    [[ "$arch" == "aarch64" || "$arch" == "arm64" ]] && arch="arm64"
    binary_name="oah-agent-${os}-${arch}"
    curl -fsSL "$OAH_BASE/$binary_name?nc=$nc" -o "$HOME/.oah-agent"
    chmod +x "$HOME/.oah-agent"
    echo "✅ ~/.oah-agent 업데이트 완료"
  fi
  if _is_running; then
    echo "→ 재시작 중..."
    cmd_restart
  fi
}

# ─── Service 관리 ─────────────────────────────────────────────────────────────

_service_name="oah-agent"

_install_systemd() {
  local unit_dir="$HOME/.config/systemd/user"
  local unit_file="$unit_dir/$_service_name.service"
  mkdir -p "$unit_dir"

  local exe_cmd; exe_cmd=$(_exe_cmd)
  # exe_cmd 는 "node /path/to/file.js" 혹은 "/path/to/binary" 형태
  local exec_start="$HOME/.oah-agent"
  _is_arm32 && exec_start="/usr/bin/env node $HOME/.oah-agent.js"

  cat > "$unit_file" <<UNIT
[Unit]
Description=OAH Agent Daemon (open-agent-harness)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=$exec_start
Restart=on-failure
RestartSec=10
StandardOutput=append:$OAH_LOG
StandardError=append:$OAH_LOG
Environment="STATE_SERVER=$PHOENIX"
Environment="AGENT_NAME=$NAME"
Environment="AGENT_ROLE=$ROLE"
Environment="AGENT_BACKEND=$BACKEND"
Environment="WORK_KEY=${WK:-}"
Environment="PROJECT_DIR=$DIR"
Environment="PATH=$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin"

[Install]
WantedBy=default.target
UNIT

  systemctl --user daemon-reload
  systemctl --user enable "$_service_name"
  systemctl --user start "$_service_name"
  echo "✅ systemd 서비스 설치 완료"
  echo "   oah service status  — 상태 확인"
  echo "   oah service logs    — 로그 보기"
  echo "   oah service stop    — 중지"
}

_install_launchd() {
  local plist_dir="$HOME/Library/LaunchAgents"
  local plist="$plist_dir/ai.baryon.$_service_name.plist"
  mkdir -p "$plist_dir"

  local exec_start="$HOME/.oah-agent"

  cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>             <string>ai.baryon.oah-agent</string>
  <key>ProgramArguments</key>  <array><string>$exec_start</string></array>
  <key>RunAtLoad</key>         <true/>
  <key>KeepAlive</key>         <true/>
  <key>StandardOutPath</key>   <string>$OAH_LOG</string>
  <key>StandardErrorPath</key> <string>$OAH_LOG</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>STATE_SERVER</key>    <string>$PHOENIX</string>
    <key>AGENT_NAME</key>      <string>$NAME</string>
    <key>AGENT_ROLE</key>      <string>$ROLE</string>
    <key>AGENT_BACKEND</key>   <string>$BACKEND</string>
    <key>WORK_KEY</key>        <string>${WK:-}</string>
    <key>PROJECT_DIR</key>     <string>$DIR</string>
    <key>PATH</key>            <string>$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
PLIST

  launchctl load "$plist" 2>/dev/null || launchctl bootstrap gui/"$(id -u)" "$plist" 2>/dev/null || true
  echo "✅ launchd 서비스 설치 완료"
  echo "   oah service status  — 상태 확인"
}

cmd_service() {
  _require_config
  local sub="${2:-help}"

  case "$sub" in
    install)
      echo "→ 서비스 설치 중..."
      if [[ "$(uname)" == "Darwin" ]]; then
        _install_launchd
      elif command -v systemctl &>/dev/null; then
        _install_systemd
      else
        echo "오류: systemd / launchd 를 찾을 수 없습니다."
        exit 1
      fi
      ;;

    remove|uninstall)
      if [[ "$(uname)" == "Darwin" ]]; then
        local plist="$HOME/Library/LaunchAgents/ai.baryon.$_service_name.plist"
        launchctl unload "$plist" 2>/dev/null || true
        rm -f "$plist"
        echo "✅ launchd 서비스 제거 완료"
      else
        systemctl --user stop "$_service_name" 2>/dev/null || true
        systemctl --user disable "$_service_name" 2>/dev/null || true
        rm -f "$HOME/.config/systemd/user/$_service_name.service"
        systemctl --user daemon-reload
        echo "✅ systemd 서비스 제거 완료"
      fi
      ;;

    start)
      if [[ "$(uname)" == "Darwin" ]]; then
        launchctl start "ai.baryon.$_service_name" 2>/dev/null || true
      else
        systemctl --user start "$_service_name"
      fi
      echo "✅ 서비스 시작됨"
      ;;

    stop)
      if [[ "$(uname)" == "Darwin" ]]; then
        launchctl stop "ai.baryon.$_service_name" 2>/dev/null || true
      else
        systemctl --user stop "$_service_name"
      fi
      echo "✅ 서비스 중지됨"
      ;;

    restart)
      if [[ "$(uname)" == "Darwin" ]]; then
        launchctl stop "ai.baryon.$_service_name" 2>/dev/null || true
        sleep 1
        launchctl start "ai.baryon.$_service_name" 2>/dev/null || true
      else
        systemctl --user restart "$_service_name"
      fi
      echo "✅ 서비스 재시작됨"
      ;;

    status)
      if [[ "$(uname)" == "Darwin" ]]; then
        local plist="$HOME/Library/LaunchAgents/ai.baryon.$_service_name.plist"
        if [[ -f "$plist" ]]; then
          echo "launchd 서비스: 등록됨"
          launchctl list "ai.baryon.$_service_name" 2>/dev/null || echo "(중지됨)"
        else
          echo "launchd 서비스: 미등록"
        fi
      else
        systemctl --user status "$_service_name" 2>/dev/null || echo "(서비스 없음)"
      fi
      ;;

    logs)
      if command -v journalctl &>/dev/null; then
        journalctl --user -u "$_service_name" -f --no-pager -n 50
      else
        tail -f "$OAH_LOG"
      fi
      ;;

    *)
      echo "사용법: oah service [install|remove|start|stop|restart|status|logs]"
      ;;
  esac
}

# ─── oah team ─────────────────────────────────────────────────────────────────
# TeamCreate / SendMessage / TaskCreate 원스톱 CLI

cmd_team() {
  local http_base="${PHOENIX/ws:/http:}"
  http_base="${http_base/wss:/https:}"
  http_base="${http_base:-http://localhost:4000}"
  local sub="${1:-status}"; shift || true

  case "$sub" in

    create)
      # oah team create "목표 설명" [--pattern pipeline|fan-out|supervisor]
      local goal="${1:-DureClaw team task}"; shift || true
      local pattern="fan-out"
      while [[ $# -gt 0 ]]; do
        case "$1" in --pattern) pattern="$2"; shift 2 ;; *) shift ;; esac
      done

      echo "━━━ TeamCreate ━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo " 목표   : $goal"
      echo " 패턴   : $pattern"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

      local wk
      wk=$(curl -sf -X POST "$http_base/api/work-keys" \
        -H "Content-Type: application/json" \
        -d "{\"goal\":\"$goal\"}" \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['work_key'])") || {
          echo "ERROR: Phoenix 서버에 연결할 수 없습니다 ($http_base)"
          exit 1
      }

      curl -sf -X PATCH "$http_base/api/state/$wk" \
        -H "Content-Type: application/json" \
        -d "{\"status\":\"running\",\"team\":{\"pattern\":\"$pattern\"}}" > /dev/null

      echo ""
      echo " ✅ Work Key 생성: $wk"
      echo ""
      echo " 에이전트 연결 명령 (Tailscale 사설망):"
      local ts_ip; ts_ip=$(tailscale ip -4 2>/dev/null || echo "")
      local lan_ip; lan_ip=$(ipconfig getifaddr en0 2>/dev/null || hostname -I 2>/dev/null | awk '{print $1}' || echo "")
      [[ -n "$ts_ip"  ]] && echo "   [Tailscale] WK=$wk PHOENIX=ws://$ts_ip:4000 ROLE=builder bash <(curl -fsSL $http_base/setup-agent.sh)"
      [[ -n "$lan_ip" ]] && echo "   [LAN]       WK=$wk PHOENIX=ws://$lan_ip:4000 ROLE=builder bash <(curl -fsSL $http_base/setup-agent.sh)"
      echo ""
      echo " 팀 대시보드: $http_base/api/team/$wk"
      echo " 팀 상태확인: oah team status $wk"
      ;;

    status)
      # oah team status [work_key]
      local wk="${1:-}"
      if [[ -z "$wk" ]]; then
        wk=$(curl -sf "$http_base/api/work-keys/latest" \
          | python3 -c "import sys,json; print(json.load(sys.stdin).get('work_key',''))" 2>/dev/null || echo "")
      fi
      [[ -z "$wk" ]] && { echo "Work Key 없음. oah team create 로 팀을 먼저 만드세요."; exit 1; }

      echo "━━━ Team Status: $wk ━━━━━━━━━━━━━━━━━━━━━━"
      local data; data=$(curl -sf "$http_base/api/team/$wk" 2>/dev/null || echo "{}")
      echo "$data" | python3 -c "
import sys, json
d = json.load(sys.stdin)
state = d.get('state', {})
print(f\"  목표   : {state.get('goal','?')}\")
print(f\"  상태   : {state.get('status','?')}\")
print(f\"  온라인 : {d.get('online_count', 0)} 에이전트\")
for a in d.get('online_agents', []):
    print(f\"    - {a.get('name','?')} [{a.get('role','?')}] @ {a.get('machine','?')}\")
print(f\"  대기중 : {d.get('pending_count', 0)} 태스크\")
for t in d.get('pending_tasks', []):
    print(f\"    - {t.get('task_id','?')} → {t.get('to','?')}\")
"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      ;;

    send)
      # oah team send <agent> <message> [--wk WORK_KEY]
      local to="${1:?'수신자 에이전트 이름 필요'}"; shift
      local msg="${1:?'메시지 내용 필요'}"; shift
      local wk="${WK:-}"
      while [[ $# -gt 0 ]]; do
        case "$1" in --wk) wk="$2"; shift 2 ;; *) shift ;; esac
      done
      [[ -z "$wk" ]] && wk=$(curl -sf "$http_base/api/work-keys/latest" \
        | python3 -c "import sys,json; print(json.load(sys.stdin).get('work_key',''))" 2>/dev/null || echo "")

      echo "→ SendMessage: $NAME → $to"
      local resp
      resp=$(curl -sf -X POST "$http_base/api/mailbox/$to" \
        -H "Content-Type: application/json" \
        -d "{\"from\":\"$NAME\",\"type\":\"info\",\"content\":\"$msg\",\"work_key\":\"$wk\"}")
      echo " $resp"
      ;;

    task)
      # oah team task <agent> "<instructions>" [--wk WK] [--id TASK_ID] [--deps task1,task2]
      local to="${1:?'에이전트 이름 필요'}"; shift
      local instructions="${1:?'태스크 지시사항 필요'}"; shift
      local wk="${WK:-}"; local task_id="task-$(date +%s)"; local deps="[]"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --wk)   wk="$2"; shift 2 ;;
          --id)   task_id="$2"; shift 2 ;;
          --deps) deps="[\"${2//,/\",\"}\"]"; shift 2 ;;
          *)      shift ;;
        esac
      done
      [[ -z "$wk" ]] && wk=$(curl -sf "$http_base/api/work-keys/latest" \
        | python3 -c "import sys,json; print(json.load(sys.stdin).get('work_key',''))" 2>/dev/null || echo "")

      echo "→ TaskCreate: $task_id → $to"
      local resp
      resp=$(curl -sf -X POST "$http_base/api/task" \
        -H "Content-Type: application/json" \
        -d "{\"work_key\":\"$wk\",\"to\":\"$to\",\"task_id\":\"$task_id\",\"instructions\":\"$instructions\",\"depends_on\":$deps}")
      echo " $resp"
      echo ""
      echo " 결과 확인: oah team result $task_id"
      ;;

    result)
      # oah team result <task_id> [--wait]
      local task_id="${1:?'task_id 필요'}"; shift
      local wait_flag=false
      [[ "${1:-}" == "--wait" ]] && wait_flag=true

      local url="$http_base/api/task/$task_id"
      if $wait_flag; then
        echo "⏳ $task_id 완료 대기 중..."
        for i in $(seq 1 60); do
          local r; r=$(curl -sf "$url" 2>/dev/null || echo "{}")
          local status; status=$(echo "$r" | python3 -c "
import sys,json
d=json.load(sys.stdin)
rs=d.get('results',[])
print(rs[-1].get('status','pending') if rs else 'pending')" 2>/dev/null || echo "pending")
          [[ "$status" != "pending" ]] && { echo ""; echo "$r" | python3 -c "
import sys,json
for r in json.load(sys.stdin).get('results',[]): print(json.dumps(r,ensure_ascii=False,indent=2))"; break; }
          printf "\r  %ds..." "$((i*5))"
          sleep 5
        done
      else
        local r; r=$(curl -sf "$url" 2>/dev/null || echo "{}")
        echo "$r" | python3 -c "
import sys,json
d=json.load(sys.stdin)
rs=d.get('results',[])
if not rs: print('결과 없음 (아직 실행 중 또는 존재하지 않는 task_id)')
else:
    for r in rs: print(json.dumps(r,ensure_ascii=False,indent=2))"
      fi
      ;;

    agents|presence)
      echo "━━━ 온라인 에이전트 ━━━━━━━━━━━━━━━━━━━━━━━━━"
      curl -sf "$http_base/api/presence" | python3 -c "
import sys,json
data=json.load(sys.stdin)
agents=data.get('agents',[])
if not agents: print('  (온라인 에이전트 없음)')
for a in agents:
    print(f\"  {a.get('name','?')} [{a.get('role','?')}] @ {a.get('machine','?')} wk={a.get('work_key','?')}\")
" 2>/dev/null || echo "  (응답 없음)"
      ;;

    *)
      echo "oah team 사용법:"
      echo "  oah team create \"목표\"      — TeamCreate: 새 팀 + Work Key 생성"
      echo "  oah team status [WK]        — 팀 상태, 온라인 에이전트, 대기 태스크"
      echo "  oah team agents             — 전체 온라인 에이전트 목록"
      echo "  oah team send <to> \"메시지\" — SendMessage: 에이전트에게 메시지"
      echo "  oah team task <to> \"지시\"   — TaskCreate: 태스크 할당"
      echo "  oah team result <task_id>   — 태스크 결과 조회"
      echo "  oah team result <task_id> --wait  — 완료까지 대기"
      ;;
  esac
}

cmd_help() {
  cat <<'HELP'

  oah — Open Agent Harness CLI

  기본 명령어:
    oah                    포그라운드 실행 (설정 없으면 마법사 실행)
    oah start              백그라운드 실행
    oah stop               중지
    oah restart            재시작
    oah status             상태 확인 (프로세스, 서버 연결, 서비스)
    oah logs [n]           로그 보기 (기본 50줄, 실시간)
    oah kill               실행 중 에이전트 강제 종료

  설정 관리:
    oah init               설정 재마법사 (서버/역할 변경)
    oah config             현재 설정 출력
    oah config set K=V     설정 값 변경 (예: PHOENIX=ws://...:4000)
    oah update             최신 버전으로 업데이트

  Soul (에이전트 정체성):
    oah soul init          머신 정보 자동 스캔 → soul.md 생성
    oah soul show          현재 soul 출력
    oah soul edit          soul 편집 ($EDITOR)

  진단:
    oah doctor             전체 시스템 진단 (서버·백엔드·바이너리·PATH)

  서비스 관리:
    oah service install    systemd(Linux/Pi) / launchd(macOS) 서비스 등록
    oah service remove     서비스 제거
    oah service start/stop/restart/status/logs

  셸 자동완성:
    source <(oah completions bash)   # bash
    source <(oah completions zsh)    # zsh

  설정 파일: ~/.oah/config
    PHOENIX=ws://oah.local:4000
    ROLE=builder          # builder | orchestrator | executor | analyzer
    BACKEND=auto          # auto | claude | opencode | gemini | zeroclaw
    DIR=/home/user/projects

HELP
}

# ─── 포그라운드 실행 ──────────────────────────────────────────────────────────

cmd_run() {
  _require_config
  _print_banner
  local exe_cmd; exe_cmd=$(_exe_cmd)
  # shellcheck disable=SC2086
  exec _run_env $exe_cmd
}

# ─── 메인 ─────────────────────────────────────────────────────────────────────

CMD="${1:-run}"
shift || true

case "$CMD" in
  status)               cmd_status "$@" ;;
  start)                cmd_start "$@" ;;
  stop)                 cmd_stop "$@" ;;
  restart)              cmd_restart "$@" ;;
  logs)                 cmd_logs "$@" ;;
  config)               cmd_config "$@" ;;
  update)               cmd_update "$@" ;;
  team)                 cmd_team "$@" ;;
  soul)                 cmd_soul "${1:-show}" ;;
  init|setup|onboard)   cmd_init ;;
  doctor|check|diag)    cmd_doctor ;;
  kill|estop|force-stop) cmd_kill ;;
  completions|completion) cmd_completions "${1:-bash}" ;;
  service)              cmd_service "$CMD" "$@" ;;
  help|--help|-h)       cmd_help ;;
  run|"")               cmd_run ;;
  *)
    echo "알 수 없는 명령어: $CMD"
    echo "  oah help 로 사용법을 확인하세요."
    exit 1 ;;
esac
